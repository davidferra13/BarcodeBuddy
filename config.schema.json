{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://barcodebuddy.local/config.schema.json",
  "title": "Barcode Buddy Configuration",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "input_path",
    "processing_path",
    "output_path",
    "rejected_path",
    "log_path",
    "barcode_types",
    "scan_all_pages",
    "duplicate_handling",
    "file_stability_delay_ms",
    "max_pages_scan"
  ],
  "properties": {
    "workflow_key": {
      "type": "string",
      "default": "default",
      "pattern": "^[a-z0-9][a-z0-9_-]{0,63}$"
    },
    "input_path": {
      "type": "string",
      "minLength": 1
    },
    "processing_path": {
      "type": "string",
      "minLength": 1
    },
    "output_path": {
      "type": "string",
      "minLength": 1
    },
    "rejected_path": {
      "type": "string",
      "minLength": 1
    },
    "log_path": {
      "type": "string",
      "minLength": 1
    },
    "barcode_types": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "barcode_value_patterns": {
      "type": "array",
      "default": [],
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "scan_all_pages": {
      "type": "boolean"
    },
    "duplicate_handling": {
      "type": "string",
      "enum": ["timestamp", "reject"]
    },
    "file_stability_delay_ms": {
      "type": "integer",
      "minimum": 500
    },
    "max_pages_scan": {
      "type": "integer",
      "minimum": 1
    },
    "poll_interval_ms": {
      "type": "integer",
      "default": 500,
      "minimum": 100
    },
    "barcode_scan_dpi": {
      "type": "integer",
      "default": 300,
      "minimum": 72
    },
    "barcode_upscale_factor": {
      "type": "number",
      "default": 1.0,
      "minimum": 1.0
    },
    "server_host": {
      "type": "string",
      "default": "0.0.0.0",
      "description": "Host interface for the web server to bind to."
    },
    "server_port": {
      "type": "integer",
      "default": 8080,
      "minimum": 1,
      "maximum": 65535,
      "description": "Port for the web server to bind to."
    },
    "secret_key": {
      "type": "string",
      "default": "",
      "description": "Persistent JWT secret key. If empty, a random key is generated on each startup (sessions will not survive restarts)."
    }
  }
}
